<Window x:Class="AirReceiver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="AirReceiver" Height="750" Width="850"
        WindowStyle="None" AllowsTransparency="True" WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip">
    
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0F172A" Offset="0.0" />
            <GradientStop Color="#1E293B" Offset="1.0" />
        </LinearGradientBrush>
    </Window.Background>

    <Window.Resources>
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowCloseButton" TargetType="Button" BasedOn="{StaticResource WindowControlButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#475569"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#475569"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1E293B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0ea5e9" Offset="0.0"/>
                        <GradientStop Color="#2563eb" Offset="1.0"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#475569"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#38bdf8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#cbd5e1"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Border x:Name="Border" Width="20" Height="20" Background="#1E293B" BorderBrush="#475569" BorderThickness="1" CornerRadius="4">
                                <Path x:Name="CheckMark" Data="M 4,10 L 8,14 L 16,6" Stroke="White" StrokeThickness="2" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Border" Property="Background" Value="#2563eb"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#2563eb"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#38bdf8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DropShadowEffect x:Key="CardShadow" BlurRadius="20" ShadowDepth="5" Opacity="0.3" Color="Black" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <tb:TaskbarIcon x:Name="MyNotifyIcon" ToolTipText="AirReceiver - Ready" TrayMouseDoubleClick="MyNotifyIcon_TrayMouseDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Open AirReceiver" Click="MenuItem_Open_Click" />
                    <Separator />
                    <MenuItem Header="Fix Firewall" Click="MenuItem_FixFirewall_Click" />
                    <Separator />
                    <MenuItem Header="Exit" Click="MenuItem_Exit_Click" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- Custom Title Bar -->
        <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="🗕" Width="46" Style="{StaticResource WindowControlButton}" Click="MinimizeButton_Click"/>
                <Button Content="🗖" Width="46" Style="{StaticResource WindowControlButton}" Click="MaximizeButton_Click"/>
                <Button Content="✕" Width="46" Style="{StaticResource WindowCloseButton}" Click="CloseButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- Main Content Area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Width="660" Margin="0,10,0,40">
                <TextBlock Text="AirReceiver" Foreground="White" HorizontalAlignment="Center" FontSize="36" FontWeight="Bold"/>
                <TextBlock x:Name="StatusText" Text="Waiting for screen mirroring connections..." Foreground="#94a3b8" HorizontalAlignment="Center" Margin="0,16,0,0" FontSize="16" TextAlignment="Center" TextWrapping="Wrap"/>

                <!-- Android / Windows Cast Card -->
                <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Margin="0,34,0,0" Padding="25" Effect="{StaticResource CardShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Android / Windows Cast" Foreground="White" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock x:Name="MiracastStatusText" Grid.Row="1" Text="Checking Wireless Display support..." Foreground="#94a3b8" Margin="0,8,0,24" TextWrapping="Wrap" />
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="Open Wireless Display" Style="{StaticResource PrimaryButton}" Margin="0,0,12,0" Click="OpenWirelessDisplay_Click" />
                            <Button Content="Projection Settings" Style="{StaticResource ModernButton}" Margin="0,0,12,0" Click="OpenProjectionSettings_Click" />
                            <Button Content="Optional Features" Style="{StaticResource ModernButton}" Click="InstallWirelessDisplay_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Apple AirPlay Card -->
                <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Margin="0,20,0,0" Padding="25" Effect="{StaticResource CardShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Apple AirPlay" Foreground="White" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="Manage your active AirPlay screen mirroring session." Foreground="#94a3b8" Grid.Row="1" Margin="0,8,0,24" TextWrapping="Wrap" />
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="Disconnect Devices" Style="{StaticResource ModernButton}" Click="DisconnectAirPlay_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Settings Card -->
                <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Margin="0,20,0,0" Padding="25" Effect="{StaticResource CardShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Settings" Foreground="White" FontSize="20" FontWeight="SemiBold" />
                        
                        <StackPanel Grid.Row="1" Margin="0,16,0,24">
                            <Grid Margin="0,0,0,20">
                                <TextBlock Text="AirPlay Receiver Name" Foreground="#cbd5e1" VerticalAlignment="Center" FontSize="15" FontWeight="Medium" />
                                <TextBox x:Name="ReceiverNameTextBox" Width="280" HorizontalAlignment="Right" FontSize="15" />
                            </Grid>
                            <CheckBox x:Name="FullscreenCheckBox" Content="Launch Video in Fullscreen" />
                            <CheckBox x:Name="BorderlessCheckBox" Content="Launch as Borderless Window" />
                            <CheckBox x:Name="AlwaysOnTopCheckBox" Content="Keep Video Always on Top" />
                            <CheckBox x:Name="StartupCheckBox" Content="Run AirReceiver silently at Windows Startup" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Fix Firewall" Style="{StaticResource ModernButton}" Margin="0,0,12,0" Click="FixFirewall_Click" />
                            <Button Content="Save Settings" Style="{StaticResource PrimaryButton}" Click="SaveSettings_Click" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
